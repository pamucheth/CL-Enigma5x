dependencies:
  flutter:
    sdk: flutter
  camera: ^0.11.0 # Or latest
  permission_handler: ^11.3.1

import 'package:flutter/material.dart';
import 'package:camera/camera.dart';
import 'package:permission_handler/permission_handler.dart';

// Global brand color
const Color kBrandTeal = Color(0xFF26C6DA);

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  // Get available cameras early for the capture screen
  final cameras = await availableCameras();
  runApp(MaterialApp(
    debugShowCheckedModeBanner: false,
    home: PermissionScreen(cameras: cameras),
  ));
}

// --- SCREEN 1: PERMISSION ---
class PermissionScreen extends StatelessWidget {
  final List<CameraDescription> cameras;
  const PermissionScreen({super.key, required this.cameras});

  Future<void> _handlePermission(BuildContext context) async {
    final status = await Permission.camera.request();
    if (status.isGranted) {
      if (!context.mounted) return;
      Navigator.push(
        context,
        MaterialPageRoute(builder: (context) => CaptureScreen(cameras: cameras)),
      );
    } else {
      // Handle denied state (show snackbar or dialog)
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text("Camera permission is required.")),
      );
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: kBrandTeal,
      body: Center(
        child: Padding(
          padding: const EdgeInsets.all(24.0),
          child: Container(
            padding: const EdgeInsets.all(32.0),
            decoration: BoxDecoration(color: Colors.white, borderRadius: BorderRadius.circular(28.0)),
            child: Column(
              mainAxisSize: MainAxisSize.min,
              children: [
                _buildCameraIllustration(),
                const SizedBox(height: 32),
                const Text('Take photos', style: TextStyle(fontSize: 24, fontWeight: FontWeight.bold)),
                const SizedBox(height: 16),
                const Text(
                  'By allowing us access to your camera you can take photos of your moles and skin conditions.',
                  textAlign: TextAlign.center,
                  style: TextStyle(fontSize: 16, color: Colors.black54, height: 1.5),
                ),
                const SizedBox(height: 40),
                SizedBox(
                  width: double.infinity,
                  height: 56,
                  child: ElevatedButton(
                    onPressed: () => _handlePermission(context),
                    style: ElevatedButton.styleFrom(
                      backgroundColor: kBrandTeal,
                      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
                    ),
                    child: const Text('Continue', style: TextStyle(color: Colors.white, fontSize: 18)),
                  ),
                ),
                TextButton(
                  onPressed: () => Navigator.pop(context),
                  child: const Text('DO NOT ALLOW', style: TextStyle(color: kBrandTeal, fontWeight: FontWeight.bold)),
                ),
              ],
            ),
          ),
        ),
      ),
    );
  }

  Widget _buildCameraIllustration() {
    return Container(
      width: 120, height: 120,
      decoration: BoxDecoration(color: const Color(0xFFF5E6D3), borderRadius: BorderRadius.circular(16)),
      child: const Icon(Icons.camera_alt, size: 60, color: Color(0xFFFFD54F)),
    );
  }
}

// --- SCREEN 2: CAPTURE ---
class CaptureScreen extends StatefulWidget {
  final List<CameraDescription> cameras;
  const CaptureScreen({super.key, required this.cameras});

  @override
  State<CaptureScreen> createState() => _CaptureScreenState();
}

class _CaptureScreenState extends State<CaptureScreen> {
  late CameraController _controller;
  late Future<void> _initializeControllerFuture;

  @override
  void initState() {
    super.initState();
    _controller = CameraController(widget.cameras.first, ResolutionPreset.high);
    _initializeControllerFuture = _controller.initialize();
  }

  @override
  void dispose() {
    _controller.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Colors.black,
      appBar: AppBar(
        backgroundColor: Colors.white,
        title: const Text('New Diagnosis', style: TextStyle(color: Colors.black)),
        centerTitle: true,
        leading: const BackButton(color: Colors.black),
      ),
      body: Column(
        children: [
          Expanded(
            child: Padding(
              padding: const EdgeInsets.all(16.0),
              child: Container(
                decoration: BoxDecoration(
                  borderRadius: BorderRadius.circular(24),
                  border: Border.all(color: kBrandTeal, width: 3),
                ),
                child: ClipRRect(
                  borderRadius: BorderRadius.circular(21),
                  child: FutureBuilder<void>(
                    future: _initializeControllerFuture,
                    builder: (context, snapshot) {
                      if (snapshot.connectionState == ConnectionState.done) {
                        return CameraPreview(_controller);
                      }
                      return const Center(child: CircularProgressIndicator());
                    },
                  ),
                ),
              ),
            ),
          ),
          const Padding(
            padding: EdgeInsets.all(16.0),
            child: Text('Image clear. Ready for analysis.', style: TextStyle(color: kBrandTeal)),
          ),
          Container(
            color: Colors.white,
            padding: const EdgeInsets.symmetric(vertical: 24, horizontal: 40),
            child: Row(
              mainAxisAlignment: MainAxisAlignment.spaceBetween,
              children: [
                const Icon(Icons.flash_off),
                GestureDetector(
                  onTap: () => Navigator.push(context, MaterialPageRoute(builder: (context) => const ResultScreen())),
                  child: Container(
                    padding: const EdgeInsets.all(16),
                    decoration: const BoxDecoration(color: kBrandTeal, shape: BoxShape.circle),
                    child: const Icon(Icons.camera_alt, color: Colors.white, size: 32),
                  ),
                ),
                const Icon(Icons.image_outlined),
              ],
            ),
          )
        ],
      ),
    );
  }
}

// --- SCREEN 3: RESULT ---
class ResultScreen extends StatelessWidget {
  const ResultScreen({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Colors.white,
      appBar: AppBar(
        backgroundColor: Colors.white, elevation: 0,
        title: const Text('Diagnosis Result', style: TextStyle(color: Colors.black)),
        centerTitle: true,
        leading: const BackButton(color: Colors.black),
      ),
      body: Padding(
        padding: const EdgeInsets.all(24.0),
        child: Column(
          children: [
            const SizedBox(height: 40),
            Container(
              padding: const EdgeInsets.all(32),
              decoration: BoxDecoration(
                color: Colors.white,
                borderRadius: BorderRadius.circular(32),
                boxShadow: [BoxShadow(color: Colors.black.withOpacity(0.05), blurRadius: 20)],
              ),
              child: Column(
                children: [
                  const Text('CL DETECTED', style: TextStyle(fontSize: 28, fontWeight: FontWeight.bold, color: Colors.pink)),
                  const SizedBox(height: 32),
                  SizedBox(
                    width: 150, height: 150,
                    child: CircularProgressIndicator(
                      value: 0.75, strokeWidth: 10,
                      backgroundColor: Colors.grey[200],
                      valueColor: const AlwaysStoppedAnimation<Color>(kBrandTeal),
                    ),
                  ),
                  const SizedBox(height: 32),
                  const Text('Edge irregularity and characteristic morphology detected.', textAlign: TextAlign.center),
                ],
              ),
            ),
            const Spacer(),
            ElevatedButton.icon(
              onPressed: () => Navigator.pop(context),
              icon: const Icon(Icons.refresh),
              label: const Text('Retake Image'),
              style: ElevatedButton.styleFrom(
                backgroundColor: Colors.grey[100], foregroundColor: Colors.black,
                minimumSize: const Size(200, 50),
              ),
            ),
            const SizedBox(height: 40),
          ],
        ),
      ),
    );
  }
}
